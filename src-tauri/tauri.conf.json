{
  "productName": "AI Cursor",
  "version": "0.1.0",
  "identifier": "com.aicursor.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "AI Cursor",
        "visible": false,
        "width": 1,
        "height": 1,
        "decorations": false,
        "skipTaskbar": true,
        "resizable": false
      },
      {
        "label": "overlay",
        "title": "AI Cursor",
        "visible": false,
        "width": 440,
        "height": 64,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": true,
        "resizable": false,
        "skipTaskbar": true,
        "shadow": false
      },
      {
        "label": "settings",
        "title": "AI Cursor — Settings",
        "visible": false,
        "width": 460,
        "height": 580,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "skipTaskbar": false,
        "center": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Shoumik Goswami",
    "copyright": "Copyright © 2025 Shoumik Goswami",
    "category": "Productivity",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ],
    "resources": [],
    "windows": {
      "digestAlgorithm": "sha256",
      "certificateThumbprint": null,
      "timestampUrl": ""
    },
    "macOS": {
      "minimumSystemVersion": "11.0",
      "entitlements": "entitlements.plist"
    }
  }
}
